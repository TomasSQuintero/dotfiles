# Vim-style half-page scrolling
screen_down <C-d>
screen_up <C-u>
prev_state <C-o>
toggle_titlebar <C-w>
next_state <C-i>
zoom_in J
zoom_out K


# Toggle dark mode with 'i' (for "invert")
toggle_dark_mode i
toggle_custom_color c
reload_config r
helper_window

add_highlight a

toggle_fullscreen f

move_left h
move_right l

fit_to_page_width s
fit_to_page_height S

previous_page <left>
next_page <right>

toggle_statusbar <C-n>

quit Q
close_window q
